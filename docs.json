{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BustedSolver",
  "logo": {
    "dark": "/logo/logo-dark.png",
    "light": "/logo/logo-light.png"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "navbar": {
    "links": [
      {
        "label": "API Status",
        "href": "https://api.bustedcap.com/api/usage"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://t.me/bustedcreator"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["introduction"]
      },
      {
        "group": "API Reference",
        "pages": ["solve", "usage", "errors"]
      },
      {
        "group": "SDK",
        "pages": ["sdk"]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/busted-creator/bustedsolver"
    }
  },
  "api": {
    "baseUrl": "https://api.bustedcap.com"
  }
}
