{
  "$schema": "https://mintlify.com/schema.json",
  "name": "BustedSolver",
  "logo": {
    "dark": "/logo/logo-dark.svg",
    "light": "/logo/logo-light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED",
    "background": {
      "dark": "#0A0A0B"
    },
    "anchors": {
      "from": "#8B5CF6",
      "to": "#6D28D9"
    }
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "topbarLinks": [
    {
      "name": "API Status",
      "url": "https://api.bustedcap.com/api/usage"
    }
  ],
  "topbarCtaButton": {
    "name": "Get API Key",
    "url": "https://t.me/bustedcreator"
  },
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/busted-creator/bustedsolver"
    }
  ],
  "navigation": [
    {
      "group": "Getting Started",
      "pages": ["introduction"]
    },
    {
      "group": "API Reference",
      "pages": ["solve", "usage", "errors"]
    },
    {
      "group": "SDK",
      "pages": ["sdk"]
    }
  ],
  "footerSocials": {
    "github": "https://github.com/busted-creator/bustedsolver"
  },
  "backgroundImage": "/background.png",
  "api": {
    "baseUrl": "https://api.bustedcap.com"
  },
  "theme": "prism"
