{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BustedSolver",
  "appearance": {
    "default": "dark"
  },
  "logo": {
    "dark": "/logo/logo-dark.png",
    "light": "/logo/logo-light.png"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#0a0d12",
    "light": "#6366f1",
    "dark": "#ffffff"
  },
  "font": {
    "headings": {
      "family": "Instrument Serif",
      "weight": 400
    },
    "body": {
      "family": "Inter",
      "weight": 400
    },
    "code": {
      "family": "Geist Mono"
    }
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "rounded": "lg",
  "tabs": [],
  "anchors": [],
  "navbar": {
    "links": [
      {
        "label": "API Status",
        "href": "https://api.bustedcap.com/health"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://t.me/bustedcreator"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["introduction", "authentication", "rate-limits"]
      },
      {
        "group": "API Reference",
        "pages": ["solve", "tokenize", "usage", "errors"]
      },
      {
        "group": "SDK",
        "pages": ["sdk"]
      },
      {
        "group": "Guides",
        "pages": ["best-practices", "faq"]
      },
      {
        "group": "Updates",
        "pages": ["changelog"]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/busted-creator/bustedsolver"
    }
  },
  "api": {
    "baseUrl": "https://api.bustedcap.com"
  }
}
